#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 80

&lt { tapping-term-ms = <140>; };

/ {
    behaviors {
        rot_kp: sensor_rotate_kp {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&kp>, <&kp>;
        };

        minus_single: minus_single {
            compatible = "zmk,behavior-mod-morph";
            label = "MINUS_SINGLE";
            bindings = <&kp MINUS>, <&kp LS(INTERNATIONAL_7)>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        slash_double: slash_double {
            compatible = "zmk,behavior-mod-morph";
            label = "SLASH_DOUBLE";
            bindings = <&kp SLASH>, <&kp AT_SIGN>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        period_exclamation: period_exclamation {
            compatible = "zmk,behavior-mod-morph";
            label = "PERIOD_EXCLAMATION";
            bindings = <&kp PERIOD>, <&kp EXCLAMATION>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        comma_question: comma_question {
            compatible = "zmk,behavior-mod-morph";
            label = "COMMA_QUESTION";
            bindings = <&kp COMMA>, <&kp QUESTION>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };
    };

    combos {
        compatible = "zmk,combos";

        middle_click {
            bindings = <&mkp MCLK>;
            key-positions = <38 40>;
            layers = <5 1>;
        };
    };

    macros {
        Santen: Santen {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp QUESTION &kp T &kp INTERNATIONAL_4>;
            label = "SANTEN";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        /       |       ,       |       .       |      -        |      ;       |    ESC         |                   |           |       L      |       R       |       D       |       Y       |      P      |
        // |        A       |       O       |       E       |      I        |      U       |    SCROLLLOCK  |                   |           |       G      |       N       |       T       |       S       |      K      |
        // |        X       |       C       |       V       |      W        |      Q       |    TAB         |                   |     F     |       J      |       H       |       M       |       B       |      Z      |
        // |    L_SHIFT     |               |               |   LOWER / Jp  |    Space     |    LEFT_WIN    |                   |  R_SHIFT  |      ENTER   |  LOWER2 / Ja  |               |               |   FUN_L     |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,       |       END     |     （        |      ”        |    PAUSE_BREAK|                  |            |      （       |       ）     |        ↑      |        [      |      ]      |
        // |    HOME        |       C_SAVE  |       END     |       ）      |       U       |    SCROLLLOCK |                  |            |   Backspace   |       ←      |        ↓      |        →      |     DEL     |
        // |    UNDO        |       CUT     |       COPY    |       PASTE   |       Q       |    TAB        |                  |   PSCRN    |    ' / "      |    = / +     |    \ / |      |    ` / ~      |    INS      |
        // |    L_SHIFT     |               |               |       none    |    SPACE      |    LALT       |                  |   RSHIFT   |   ENTER       |       FUN_L  |               |               |    RCTRL    |
        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Default_layer {
            bindings = <
&kp Q      &kp W  &kp E                 &kp R  &kp T                                &mt LS(LG(S)) LG(PERIOD)  &kp Y      &kp U      &kp I         &kp O   &kp P
&kp A      &kp S  &kp D                 &kp F  &kp G                                &none                     &kp H      &kp J      &kp K         &kp L   &kp N0
&kp Z      &kp X  &kp C                 &kp V  &kp B                                &mt F10 F7                &kp N      &kp M      &kp N0        &kp N0  &kp N0
&kp LCTRL  &mo 2  &mt LEFT_SHIFT SPACE  &mo 1  &mt INTERNATIONAL_5 INTERNATIONAL_4  &mkp LCLK                 &kp ENTER  &mkp RCLK  &kp LEFT_ALT
            >;
        };

        symbol_and_number {
            bindings = <
&none  &kp LEFT_BRACKET  &kp LS(NUMBER_6)  &kp SINGLE_QUOTE  &Santen                  &none      &kp N7        &kp N8        &kp N9             &kp N0         &kp LS(SEMI)
&none  &kp HASH          &kp PERCENT       &kp SEMICOLON     &kp LS(INTERNATIONAL_1)  &none      &kp NUMBER_4  &kp N5        &kp NUMBER_6       &kp LS(MINUS)  &kp MINUS
&none  &none             &none             &none             &none                    &none      &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3       &kp PERIOD     &kp SLASH
&none  &none             &kp SPACE         &none             &none                    &mkp LCLK  &kp ENTER     &mkp RCLK     &kp DOUBLE_QUOTES
            >;
        };

        arrow_layer {
            bindings = <
&kp K_MUTE       &none  &kp ESC  &none      &kp TAB  &none          &kp HOME  &none        &kp UP_ARROW    &none      &none
&kp C_VOL_DN     &none  &kp DEL  &none      &none    &none          &kp END   &kp LEFT     &kp DOWN_ARROW  &kp RIGHT  &none
&kp C_VOLUME_UP  &none  &none    &kp LG(V)  &mo 5    &none          &none     &none        &none           &none      &none
&kp LG(H)        &none  &none    &none      &none    &kp PAGE_DOWN  &none     &kp PAGE_UP  &none
            >;
        };

        Yamato_hairetu {
            bindings = <
&kp N1      &kp N2      &kp N3      &kp N4      &kp N5      &kp ESC     &kp N6      &kp N7      &kp N8      &kp N9      &kp N0
&kp LS(N1)  &kp LS(N2)  &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &none       &kp RS(N6)  &kp RS(N7)  &kp RS(N8)  &kp RS(N9)  &kp RS(N0)
&kp F1      &kp F2      &kp F3      &kp F4      &kp F5      &kp TAB     &kp APOS    &kp EQUAL   &kp BSLH    &kp GRAVE   &kp INS
&mo 0       &mo 0       &kp SPACE   &kp LSHIFT  &kp F11     &kp RSHIFT  &kp ENTER   &none       &kp RSHIFT
            >;
        };

        not_in_use {
            bindings = <
&kp F1      &kp F2   &kp F3   &kp F4   &kp F5   &none  &kp F6   &kp F7   &kp F8      &kp F9   &kp F10
&kp F11     &kp F12  &kp F13  &kp F14  &kp F15  &none  &kp F16  &kp F17  &kp F18     &kp F19  &kp F20
&none       &none    &none    &none    &none    &none  &none    &none    &none       &none    &none
&kp LSHIFT  &none    &none    &none    &none    &none  &none    &none    &kp RSHIFT
            >;
        };

        Bluetooth_layer {
            bindings = <
&none  &none  &none  &none  &none  &none  &bt BT_CLR_ALL  &none         &none         &none  &none
&none  &none  &none  &none  &none  &none  &none           &none         &none         &none  &none
&none  &none  &none  &none  &none  &none  &bt BT_SEL 1    &bt BT_SEL 2  &bt BT_SEL 3  &none  &none
&none  &none  &none  &none  &none  &none  &none           &none         &none
            >;
        };
    };
};
